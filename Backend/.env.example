# MongoDB Connection String (required in production)
# Local:
# MONGODB_URI=mongodb://localhost:27017/portfolio
# MongoDB Atlas (production):
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.bkoa00d.mongodb.net/portfolio?retryWrites=true&w=majority&appName=Cluster0

# Server Port
PORT=5000

# Frontend URL for CORS (required for production deploy)
FRONTEND_URL=https://portfolio-frontend-za4s.onrender.com

# 1. Copy this file to .env and replace <username> / <password> with your Atlas credentials.
# 2. On production (e.g. Render), set MONGODB_URI and FRONTEND_URL in the environment.
# 3. Never commit .env or real credentials to git.
